{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/currently-playing",
      "destination": "/api/currently-playing.js"
    },
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/:path((?!api/|assets/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
